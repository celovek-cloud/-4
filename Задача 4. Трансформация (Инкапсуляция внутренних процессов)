class Werewolf:
    def __init__(self, name, form, power):
        self.__name  = name
        self.__form = form
        self.__power = power

    def get_stats(self):
        print(f'{self.__name} сейчас в форме: {self.__form}. Сила: {self.__power}')

    def transform(self):
        if self.__form == 'Человек':
            self.__form = 'Волк'
            self.__power = 45
            print(f'{self.__name} обрастает шерстью!')
        elif self.__form == 'Волк':
            self.__form = 'Человек'
            self.__power = 15
            print(f'{self.__name} снова становится человеком.')
            

m= Werewolf('lele', 'Человек', 15)
m.get_stats()
m.transform()
m.get_stats()
m.transform()
m.get_stats()
