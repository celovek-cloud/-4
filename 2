#Старинная задача
BIK_PRICE = 10
COW_PRICE = 5
TELENOK_PRICE = 0.5
TOTAL_PRICE = 100
print(f'НА {TOTAL_PRICE} рублей можно купить:')
for bik in range(1, (TOTAL_PRICE//BIK_PRICE) + 1):
   for cow in range(1, (TOTAL_PRICE//COW_PRICE) + 1):
       for telenok in range(1, (TOTAL_PRICE*2) +1):
           if  bik*BIK_PRICE+cow*COW_PRICE+telenok*TELENOK_PRICE == 100:
               print(f'{bik} быков, {cow} коров, {telenok} телят  ')
